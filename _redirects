# Cloudflare Pages _redirects — sparkcore.fund
# Format: /source /destination statusCode
# First match wins — specific rules before generic ones

# ----------------------------------------------------------------
# Block internal/dev files leaked by CF Pages default deploy
# Replaces legacy .htaccess: RewriteRule ^MD(/|$) - [F,L] and dotfile blocks.
# CF Pages excludes most dotfiles automatically (.git, .env, .DS_Store, README.md,
# _headers, _redirects, .gitattributes) but ships these by default.
# ----------------------------------------------------------------
/MD/*              /404.html  404
/.gitignore        /404.html  404
/package.json      /404.html  404
/package-lock.json /404.html  404

