# Cloudflare Pages _headers — sparkcore.fund
# Applied to static asset responses (Functions override these for their routes)

# ----------------------------------------------------------------
# Global security headers
# ----------------------------------------------------------------
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()

# ----------------------------------------------------------------
# Internal docs — never index, never serve to crawlers
# ----------------------------------------------------------------
/MD/*
  X-Robots-Tag: noindex, nofollow, noarchive

# ----------------------------------------------------------------
# Gated pages — defense in depth
# ----------------------------------------------------------------
/factsheets/*
  X-Robots-Tag: noindex, nofollow, noarchive

/factsheets
  X-Robots-Tag: noindex, nofollow, noarchive

/discovery-call
  X-Robots-Tag: noindex, nofollow, noarchive

/discovery-call.html
  X-Robots-Tag: noindex, nofollow, noarchive

/validation.html
  X-Robots-Tag: noindex, nofollow, noarchive

# ----------------------------------------------------------------
# PDFs served statically (contrats/) — no-store + noindex
# Protected PDFs go through the Function which sets its own headers
# ----------------------------------------------------------------
/ressources/contrats/*
  X-Robots-Tag: noindex, nofollow, noarchive
  Cache-Control: no-store, no-cache, must-revalidate, private
